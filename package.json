{
  "name": "canvio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "bun run --filter @canvio/database db:generate",
    "db:migrate": "bun run --filter @canvio/database db:migrate",
    "db:migrate:prod": "bun run --filter @canvio/database db:migrate:prod",
    "db:push": "bun run --filter @canvio/database db:push",
    "db:studio": "bun run --filter @canvio/database db:studio",
    "prepare": "bun run --filter @canvio/database db:generate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.21",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
